{
  "name": "drug-cup-online",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.1",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "html2canvas": "^1.4.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vue-tsc": "^3.3.3"
  }
}
