# =============================================================================
# Supabase (required)
# =============================================================================
# Get these from your Supabase project: Project Settings -> API
# https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =============================================================================
# App base URL (optional)
# =============================================================================
# Used as the base for the email-confirmation redirect URL on registration
# (e.g. https://app.example.com/waiting-for-approval).
# If unset, falls back to window.location.origin at runtime.

# VITE_APP_BASE_URL=https://app.example.com
